# --- Supabase (external project; from your Supabase dashboard) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...                       # safe; only used to verify JWT issuer
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...                # SECRET. RLS bypass. Workers + cross-user only.
SUPABASE_JWT_SECRET=                                  # legacy HS256 projects: paste the JWT secret. Leave blank for JWKS.
SUPABASE_JWT_AUDIENCE=authenticated

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/3

# --- Encryption (32-byte base64 urlsafe key for AES-GCM) ---
# Generate once with:  python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# --- Delta Exchange ---
DELTA_BASE_URL=https://api.delta.exchange
DELTA_WS_URL=wss://socket.delta.exchange
DELTA_SYMBOLS=BTCUSD,ETHUSD

# --- App ---
API_HOST=0.0.0.0
API_PORT=8010
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-dashboard.example.com,http://localhost:5173,http://localhost:8080
